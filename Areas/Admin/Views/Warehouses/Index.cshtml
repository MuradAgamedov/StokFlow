@model IEnumerable<ModernWMC.Areas.Admin.ViewModels.WarehouseViewModel>

<main id="main">
    <div class="content">

        <!-- Page Header -->
        <div class="pg-header">
            <div>
                <h4>Fiziki Anbarların İdarə Edilməsi</h4>
                <p>Sistemdə qeydiyyatdan keçmiş anbarların siyahısı, yerləşmə zonaları və tutum faizləri.</p>
            </div>
            <div>
                <a asp-area="Admin" asp-controller="Warehouses" asp-action="Create" class="btn btn-sm btn-primary shadow-sm">
                    <i class="bi bi-plus-lg me-1"></i> Yeni Anbar
                </a>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Search Panel -->
        <div class="filter-card mb-4">
            <form method="GET" asp-area="Admin" asp-controller="Warehouses" asp-action="Index">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="searchQuery">Anbar Axtar</label>
                        <input type="text" class="form-control form-control-sm" id="searchQuery" name="search" value="@ViewData["CurrentFilter"]" placeholder="Anbar adı, ünvan, kod və ya məsul şəxs..." />
                    </div>
                    <div class="col-12 col-md-3">
                        <button type="submit" class="btn btn-sm btn-primary w-100">
                            <i class="bi bi-funnel me-1"></i> Filtrlə
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Warehouses Table Card -->
        <div class="cc">
            <div class="cc-head">
                <h5 class="cc-title">Anbarların Siyahısı</h5>
                <span class="badge bg-secondary">Cəmi: @(Model?.Count() ?? 0) anbar</span>
            </div>
            <div class="cc-body">
                <div class="table-responsive">
                    <table class="table erp-table align-middle">
                        <thead>
                            <tr>
                                <th>KOD</th>
                                <th>Anbar Adı</th>
                                <th>Ünvan / Yerləşmə</th>
                                <th>Məsul Şəxs</th>
                                <th class="text-end">Tutum Limit</th>
                                <th class="text-center">Doluluq</th>
                                <th class="text-center">Status</th>
                                <th class="text-center">Əməliyyatlar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    var barColorClass = item.OccupancyPercentage >= 80 ? "bg-warning" : "bg-success";
                                    if (item.OccupancyPercentage >= 95)
                                    {
                                        barColorClass = "bg-danger";
                                    }
                                    
                                    <tr>
                                        <td><span class="sku">@item.Code</span></td>
                                        <td><strong>@item.Name</strong></td>
                                        <td>@(string.IsNullOrWhiteSpace(item.Address) ? "-" : item.Address)</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.ContactPerson) ? "-" : item.ContactPerson)</td>
                                        <td class="text-end fw-bold">@(item.Capacity.HasValue ? $"{item.Capacity:N0} m³" : "-")</td>
                                        <td class="text-center">
                                            <div class="d-flex align-items-center justify-content-center gap-2">
                                                <div class="progress w-50" style="height: 6px;">
                                                    <div class="progress-bar @barColorClass" role="progressbar" style="width: @item.OccupancyPercentage%;" aria-valuenow="@item.OccupancyPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                                                </div>
                                                <span class="fs-8 fw-bold">@item.OccupancyPercentage%</span>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            @if (item.IsActive)
                                            {
                                                <span class="sbadge s-ok">Aktiv</span>
                                            }
                                            else
                                            {
                                                <span class="sbadge s-err">Deaktiv</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex justify-content-center gap-1">
                                                <a asp-area="Admin" asp-controller="Warehouses" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-xs btn-outline-primary act-btn" title="Düzəliş et">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form asp-area="Admin" asp-controller="Warehouses" asp-action="Delete" asp-route-id="@item.Id" method="POST" class="d-inline" onsubmit="return confirm('Bu anbarı silmək istədiyinizə əminsiniz?')">
                                                    <button type="submit" class="btn btn-xs btn-outline-danger act-btn" title="Sil">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center text-muted py-4">Sistemdə heç bir anbar tapılmadı.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</main>
