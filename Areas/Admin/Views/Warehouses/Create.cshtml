@model ModernWMC.Areas.Admin.ViewModels.WarehouseViewModel

<main id="main">
    <div class="content">
        <div class="pg-header">
            <div>
                <h4>Yeni Anbar Əlavə Et</h4>
                <p>Sistemdə malların saxlanması və idarə edilməsi üçün yeni fiziki saxlanc sahəsi qeydiyyatdan keçirin.</p>
            </div>
            <div>
                <a asp-area="Admin" asp-controller="Warehouses" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Geri Qayıt
                </a>
            </div>
        </div>

        <div class="cc">
            <div class="cc-head">
                <h5 class="cc-title"><i class="bi bi-building me-2 text-primary"></i>Anbar Məlumat Forması</h5>
            </div>
            <div class="cc-body p24">
                <form method="POST" asp-area="Admin" asp-controller="Warehouses" asp-action="Create">
                    <div class="row g-3">
                        <!-- Anbar Adi -->
                        <div class="col-12 col-md-8">
                            <label class="form-label" asp-for="Name">Anbar Adı <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" asp-for="Name" required placeholder="Məsələn: Mərkəzi Anbar" />
                            <span asp-validation-for="Name" class="text-danger fs-7"></span>
                        </div>
                        <!-- Kod -->
                        <div class="col-12 col-md-4">
                            <label class="form-label" asp-for="Code">Anbar Kodu <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" asp-for="Code" required placeholder="Məsələn: WH-CENTRAL" />
                            <span asp-validation-for="Code" class="text-danger fs-7"></span>
                        </div>

                        <!-- Mesul Sexs -->
                        <div class="col-12 col-md-6">
                            <label class="form-label" asp-for="ContactPerson">Məsul Şəxs (Menecer)</label>
                            <input type="text" class="form-control" asp-for="ContactPerson" placeholder="Ad və soyad..." />
                            <span asp-validation-for="ContactPerson" class="text-danger fs-7"></span>
                        </div>
                        <!-- Həcm/Tutum -->
                        <div class="col-12 col-md-6">
                            <label class="form-label" asp-for="Capacity">Ümumi Həcm Tutumu (m³)</label>
                            <input type="number" class="form-control" asp-for="Capacity" min="1" placeholder="Məsələn: 10000" />
                            <span asp-validation-for="Capacity" class="text-danger fs-7"></span>
                        </div>

                        <!-- Ünvan -->
                        <div class="col-12">
                            <label class="form-label" asp-for="Address">Fiziki Ünvan</label>
                            <textarea class="form-control" asp-for="Address" rows="3" placeholder="Küçə adı, bina nömrəsi, şəhər..."></textarea>
                            <span asp-validation-for="Address" class="text-danger fs-7"></span>
                        </div>

                        <!-- Status -->
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" />
                                <label class="form-check-label" asp-for="IsActive">Status Aktiv</label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex gap-2 justify-content-end">
                        <a asp-area="Admin" asp-controller="Warehouses" asp-action="Index" class="btn btn-outline-secondary">İmtina Et</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Yadda Saxla</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>
