
<!DOCTYPE html>
<html lang="az" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sistemə Giriş - WMS Pro</title>

    <!-- Google Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet">

    <!-- Custom CSS (WMS Pro Styles) -->
    <link rel="stylesheet" href="wwwroot/css/site.css" />

    <style>
        body, html {
            height: 100%;
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-app);
        }

        .login-container {
            min-height: 100vh;
            display: flex;
            align-items: stretch;
        }

        /* Left Split (Branding Panel) */
        .login-brand-panel {
            background: linear-gradient(135deg, #0d6efd 0%, #063970 100%);
            color: #ffffff;
            display: flex;
            flex-direction: column;
            justify-content: justify;
            padding: 60px;
            position: relative;
            overflow: hidden;
        }

            .login-brand-panel::before {
                content: '';
                position: absolute;
                width: 300px;
                height: 300px;
                border-radius: 50%;
                background: rgba(255, 255, 255, 0.03);
                top: -100px;
                right: -100px;
            }

        .brand-logo {
            font-family: 'Outfit', sans-serif;
            font-size: 1.8rem;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #ffffff;
            text-decoration: none;
            margin-bottom: 80px;
        }

        .brand-quote {
            font-size: 1.8rem;
            font-weight: 600;
            line-height: 1.4;
            font-family: 'Outfit', sans-serif;
            margin-bottom: 20px;
        }

        /* Right Split (Form Panel) */
        .login-form-panel {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px;
            background: var(--bg-card);
            border-left: 1px solid var(--border);
        }

        .login-card-width {
            width: 100%;
            max-width: 420px;
        }

        .login-title {
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            font-size: 2rem;
            color: var(--text-main);
            margin-bottom: 8px;
        }

        .login-subtitle {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 32px;
        }

        /* Floating style for inputs */
        .form-icon-group {
            position: relative;
        }

            .form-icon-group i {
                position: absolute;
                left: 16px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                pointer-events: none;
                transition: all 0.2s ease;
            }

            .form-icon-group .form-control {
                padding-left: 48px;
                height: 50px;
                border-radius: 8px;
                border: 1px solid var(--border);
                background-color: var(--bg-app);
                color: var(--text-main);
            }

                .form-icon-group .form-control:focus {
                    border-color: #0d6efd;
                    box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.15);
                }

                    .form-icon-group .form-control:focus + i {
                        color: #0d6efd;
                    }

        .btn-login-submit {
            height: 50px;
            font-weight: 600;
            border-radius: 8px;
            background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 100%);
            border: none;
            box-shadow: 0 4px 15px rgba(13, 110, 253, 0.2);
            transition: all 0.3s ease;
        }

            .btn-login-submit:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(13, 110, 253, 0.3);
            }

        /* Floating theme switch top right */
        .theme-toggle-corner {
            position: absolute;
            top: 24px;
            right: 24px;
        }
    </style>
</head>
<body>

    @RenderBody()

    <!-- Bootstrap 5 Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom WMS Pro JS -->
    <script src="wwwroot/js/site.js"></script>
</body>
</html>
