@using Microsoft.AspNetCore.Identity
@using ModernWMC.Models.Concrete

@inject UserManager<ApplicationUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
}

<!DOCTYPE html>
<html lang="az" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>İdarə Paneli - WMS Pro (ERP/WMS Light)</title>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet">

    <!-- Custom CSS (WMS Pro Styles) -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <!-- Mobile Sidebar Overlay -->
    <div id="sbOverlay" class="sb-overlay"></div>

    <!-- SIDEBAR -->
    <aside id="sidebar">
        <!-- Brand / Logo -->
        <a href="dashboard.html" class="sb-brand">
            <div class="sb-brand-icon">
                <i class="bi bi-box-seam-fill"></i>
            </div>
            <div>
                <div class="sb-brand-name">WMS Pro</div>
                <div class="sb-brand-sub">Təchizat & Anbar ERP</div>
            </div>
        </a>

        <!-- Navigation Menu -->
        <div class="sb-nav">
            <!-- Əsas Bölmə -->
            <div class="sb-section">Əsas</div>
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="sb-link">
                <i class="bi bi-grid-1x2-fill"></i>
                <span>İdarə Paneli</span>
            </a>
            <a href="reports/index.html" class="sb-link">
                <i class="bi bi-graph-up-arrow"></i>
                <span>Statistika & Hesabatlar</span>
            </a>

            <!-- Əməliyyatlar Bölməsi -->
            <div class="sb-section">Əməliyyatlar</div>
            <a asp-area="Admin" asp-controller="Inventory" asp-action="Index" class="sb-link">
                <i class="bi bi-boxes"></i>
                <span>Anbar & Stok</span>
                <span class="badge bg-danger sb-badge rounded-pill">3</span>
            </a>
            <a asp-controller="Categories" asp-action="Index" class="sb-link">
                <i class="bi bi-tags-fill"></i>
                <span>Kateqoriyalar</span>
            </a>
            <a asp-area="Admin" asp-controller="Companies" asp-action="Index" class="sb-link">
                <i class="bi bi-briefcase-fill"></i>
                <span>Firmalar</span>
            </a>
            <a asp-area="Admin" asp-controller="Warehouses" asp-action="Index" class="sb-link">
                <i class="bi bi-building-fill-gear"></i>
                <span>Anbarlar</span>
            </a>
            <a asp-area="Admin" asp-controller="MeasureUnits" asp-action="Index" class="sb-link">
                <i class="bi bi-rulers"></i>
                <span>Ölçü Vahidləri</span>
            </a>
            <a asp-area="Admin" asp-controller="PurchaseOrders" asp-action="Index" class="sb-link">
                <i class="bi bi-cart-check-fill"></i>
                <span>Satınalma & Sifarişlər</span>
            </a>
            <a asp-area="Admin" asp-controller="Transfers" asp-action="Index" class="sb-link">
                <i class="bi bi-arrow-left-right"></i>
                <span>Anbarlararası Transfer</span>
            </a>

            <hr class="sb-divider" />

            <div class="sb-section">Məzmun (CMS)</div>
            <a asp-controller="About" asp-action="Index" class="sb-link">
                <i class="bi bi-info-circle-fill"></i>
                <span>Haqqımızda</span>
            </a>
            <a asp-controller="Privacy" asp-action="Index" class="sb-link">
                <i class="bi bi-shield-lock-fill"></i>
                <span>Gizlilik Siyasəti</span>
            </a>
            <a asp-controller="Terms" asp-action="Index" class="sb-link">
                <i class="bi bi-file-earmark-text-fill"></i>
                <span>İstifadə Şərtləri</span>
            </a>

            <a asp-controller="Faq" asp-action="Index" class="sb-link">
                <i class="bi bi-question-square-fill"></i>
                <span>FAQ İdarəetməsi</span>
            </a>
            <a asp-controller="Hero" asp-action="Index" class="sb-link">
                <i class="bi bi-window-sidebar"></i>
                <span>Hero İdarəetməsi</span>
            </a>
            <a asp-controller="Features" asp-action="Index" class="sb-link">
                <i class="bi bi-cpu-fill"></i>
                <span>Sistem Modulları</span>
            </a>
            <a asp-controller="Statistics" asp-action="Index" class="sb-link">
                <i class="bi bi-bar-chart-steps"></i>
                <span>Statistika Göstəriciləri</span>
            </a>
            <a asp-controller="Cta" asp-action="Index" class="sb-link">
                <i class="bi bi-megaphone-fill"></i>
                <span>Fəaliyyətə Çağırış (CTA)</span>
            </a>
            <a asp-controller="Locations" asp-action="Index" class="sb-link">
                <i class="bi bi-geo-alt"></i>
                <span>Ünvanlar (Locations)</span>
            </a>
            <a asp-controller="Telephones" asp-action="Index" class="sb-link">
                <i class="bi bi-telephone"></i>
                <span>Telefonlar</span>
            </a>
            <a asp-controller="Emails" asp-action="Index" class="sb-link">
                <i class="bi bi-envelope"></i>
                <span>E-poçtlar</span>
            </a>
            <a asp-controller="Maps" asp-action="Index" class="sb-link">
                <i class="bi bi-map"></i>
                <span>Xəritələr (Maps)</span>
            </a>

            <hr class="sb-divider" />

            <!-- Sistem Bölməsi -->
            <div class="sb-section">Sistem</div>
            <a href="users/index.html" class="sb-link">
                <i class="bi bi-people-fill"></i>
                <span>İstifadəçilər & Rollar</span>
            </a>
        </div>

        <!-- Sidebar Footer / User Quick Info -->
        <div class="sb-footer">
            <div class="sb-user dropdown">
                <div class="d-flex align-items-center gap-2 w-100" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="avatar">MA</div>
                    <div class="overflow-hidden flex-grow-1">
                        <div class="sb-user-name text-truncate">Murad Agamedov</div>
                        <div class="sb-user-role text-truncate">Sistem Administratoru</div>
                    </div>
                    <i class="bi bi-chevron-up text-muted ms-auto" style="font-size: 0.75rem;"></i>
                </div>
                <!-- User dropdown options -->
                <ul class="dropdown-menu dropdown-menu-dark erp-dropdown shadow w-100">
                    <li><a class="dropdown-item" href="#profile"><i class="bi bi-person me-2"></i> Profilim</a></li>
                    <li><a class="dropdown-item" href="#settings"><i class="bi bi-gear me-2"></i> Parametrlər</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>

                        <form asp-area="Admin"
                              asp-controller="Login"
                              asp-action="Logout"
                              method="post">

                            <button type="submit" class="dropdown-item">
                                Çıxış et
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </aside>

    <!-- TOP NAVBAR -->
    <header id="topbar">
        <!-- Toggle button for mobile sidebar -->
        <button id="sbToggle" class="btn btn-link text-decoration-none p-0 me-3 d-lg-none" type="button">
            <i class="bi bi-list fs-3 text-secondary"></i>
        </button>

        <!-- Breadcrumb / Section title -->
        <div>
            <div class="topbar-title">@(ViewData["PageTitle"] ?? "İdarə Paneli")</div>
            <div class="topbar-crumb d-none d-sm-block">
                <span>WMS Pro</span> / <span>@(ViewData["PageSection"] ?? "Əsas")</span> / <span class="text-secondary">@(ViewData["PageTitle"] ?? "İdarə Paneli")</span>
            </div>
        </div>

        <div class="topbar-spacer"></div>

        <!-- Dark/Light Theme Toggle -->
        <button id="themeToggle" class="icon-btn me-2" type="button" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Rejimi dəyiş">
            <i class="bi bi-moon-fill"></i>
        </button>

        <!-- User Profile Dropdown -->
        <div class="dropdown">
            <div class="avatar" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">@User.Identity?.Name?.Substring(0, 2).ToUpper()</div>
            <ul class="dropdown-menu dropdown-menu-end erp-dropdown shadow" aria-labelledby="profileDropdown">
                <li>
                    <div class="px-3 py-2 border-bottom">
                        <div class="fw-bold">@currentUser.UserName</div>
                        <div class="text-muted fs-7">@currentUser?.Email</div>
                    </div>
                </li>
                <li><a class="dropdown-item mt-1" href="#profile"><i class="bi bi-person me-2"></i> Profilim</a></li>
                <li><a class="dropdown-item" href="#settings"><i class="bi bi-gear me-2"></i> Parametrlər</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><form asp-area="Admin"
                      asp-controller="Login"
                      asp-action="Logout"
                      method="post">

                    <button type="submit" class="dropdown-item">
                        Çıxış et
                    </button>
                </form></li>
            </ul>
        </div>
    </header>

    @RenderBody()

    <!-- SHARED MODAL: BARKOD OXUYUCU -->
    <div class="modal fade" id="barcodeScanModal" tabindex="-1" aria-labelledby="barcodeScanModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="barcodeScanModalLabel"><i class="bi bi-qr-code-scan me-2 text-primary"></i>Barkod Oxuyucu Skanner</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">
                    <div class="scanner-container mb-3">
                        <div class="scanner-viewfinder">
                            <div class="scanner-laser"></div>
                            <span class="text-white fs-8" style="z-index: 10;">Barkodu bu çərçivəyə yaxınlaşdırın</span>
                        </div>
                    </div>
                    <div id="scanStatus" class="fw-bold text-primary">Kamera işə salınır...</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">İmtina Et</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap 5 Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>

