@model ModernWMC.Areas.Admin.ViewModels.CtaViewModel

<main id="main">
    <div class="content">
        <div class="pg-header">
            <div>
                <h4>Fəaliyyətə Çağırış (CTA) Banneri Məlumatları</h4>
                <p>Landing səhifəsinin ən aşağı hissəsindəki (Footer üstü) böyük rəngli çağırış bannerindəki yazıları və düymələri buradan tənzimləyin.</p>
            </div>
            <div>
                <a href="/" target="_blank" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-eye me-1"></i> Səhifəyə Baxış
                </a>
            </div>
        </div>

        <div class="cc">
            <div class="cc-head">
                <h5 class="cc-title"><i class="bi bi-megaphone me-2 text-primary"></i>CTA Forması</h5>
            </div>
            <div class="cc-body p24">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form method="POST" asp-area="Admin" asp-controller="Cta" asp-action="Index">
                    <input type="hidden" asp-for="Id" />
                    <div class="row g-3">
                        <!-- Banner Başlığı -->
                        <div class="col-12">
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger fs-7"></span>
                        </div>

                        <!-- Banner Açıqlaması -->
                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger fs-7"></span>
                        </div>

                        <!-- Düymə Mətni -->
                        <div class="col-md-6 col-12">
                            <label asp-for="ButtonText" class="form-label"></label>
                            <input asp-for="ButtonText" class="form-control" />
                            <span asp-validation-for="ButtonText" class="text-danger fs-7"></span>
                        </div>

                        <!-- Düymə Keçidi (URL) -->
                        <div class="col-md-6 col-12">
                            <label asp-for="Url" class="form-label"></label>
                            <input asp-for="Url" class="form-control" />
                            <span asp-validation-for="Url" class="text-danger fs-7"></span>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-outline-secondary" onclick="window.location.reload();">İmtina Et</button>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Dəyişiklikləri Saxla</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>
