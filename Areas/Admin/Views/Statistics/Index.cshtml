@model IEnumerable<ModernWMC.Areas.Admin.ViewModels.StatisticsViewModel>

<main id="main">
    <div class="content">
        
        <!-- Page Header -->
        <div class="pg-header">
            <div>
                <h4>Landing Səhifəsi Statistika Göstəriciləri</h4>
                <p>Landing (tanıtım) səhifəsində göstərilən rəqəmsal göstəriciləri və statistika kartlarını buradan idarə edin.</p>
            </div>
            <div>
                <a asp-area="Admin" asp-controller="Statistics" asp-action="Create" class="btn btn-sm btn-primary shadow-sm">
                    <i class="bi bi-plus-lg me-1"></i> Yeni Göstərici
                </a>
            </div>
        </div>

        <!-- Stats List Table Card -->
        <div class="cc">
            <div class="cc-head">
                <h5 class="cc-title">Göstəricilərin Siyahısı</h5>
                <span class="badge bg-secondary">Cəmi: @Model.Count() göstərici</span>
            </div>
            <div class="cc-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="table-responsive">
                    <table class="table erp-table align-middle">
                        <thead>
                            <tr>
                                <th style="width: 80px;" class="text-center">Sıra</th>
                                <th>Dəyər (Value)</th>
                                <th>Açıqlama (Label)</th>
                                <th class="text-center" style="width: 120px;">Status</th>
                                <th class="text-center" style="width: 150px;">Əməliyyatlar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center fw-bold">@item.Order</td>
                                    <td>
                                        <span class="badge bg-success-subtle text-success fs-7 px-3 py-2">@item.Title</span>
                                    </td>
                                    <td><strong>@item.Description</strong></td>
                                    <td class="text-center">
                                        @if (item.IsActive)
                                        {
                                            <span class="sbadge s-ok">Aktiv</span>
                                        }
                                        else
                                        {
                                            <span class="sbadge s-warn">Deaktiv</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-1">
                                            <!-- Düzəliş et -->
                                            <a asp-area="Admin" asp-controller="Statistics" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-xs btn-outline-primary act-btn" title="Düzəliş et">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <!-- Sil -->
                                            <form id="delete-form-@item.Id" asp-area="Admin" asp-controller="Statistics" asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:none;"></form>
                                            <button type="button" class="btn btn-xs btn-outline-danger act-btn" title="Sil" onclick="deleteStat(@item.Id, '@item.Title')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">Siyahı boşdur.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</main>

@section Scripts {
    <script>
        function deleteStat(id, val) {
            if (confirm(`"${val}" statistikasını silmək istədiyinizə əminsiniz?`)) {
                document.getElementById('delete-form-' + id).submit();
            }
        }
    </script>
}
