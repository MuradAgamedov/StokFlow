@model ModernWMC.Areas.Admin.ViewModels.StatisticsViewModel

<main id="main">
    <div class="content">
        
        <div class="pg-header">
            <div>
                <h4>Yeni Statistika Göstəricisi Əlavə Et</h4>
                <p>Landing (tanıtım) səhifəsi statistika bölməsinə yeni bir göstərici əlavə etmək üçün formanı doldurun.</p>
            </div>
        </div>

        <div class="cc">
            <div class="cc-head">
                <h5 class="cc-title"><i class="bi bi-plus-circle me-2 text-primary"></i>Statistika Forması</h5>
            </div>
            <div class="cc-body p24">
                <form method="POST" asp-area="Admin" asp-controller="Statistics" asp-action="Create">
                    <div class="row g-3">
                        <!-- Dəyər (Value) -->
                        <div class="col-md-6 col-12">
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control" placeholder="Məs: 99.9%, 150+, 1M+" />
                            <span asp-validation-for="Title" class="text-danger fs-7"></span>
                            <div class="form-text">Böyük ölçüdə görünəcək əsas rəqəmsal dəyər.</div>
                        </div>

                        <!-- Açıqlama (Label) -->
                        <div class="col-md-6 col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <input asp-for="Description" class="form-control" placeholder="Məs: Sistem Aktivliyi (Uptime)" />
                            <span asp-validation-for="Description" class="text-danger fs-7"></span>
                            <div class="form-text">Dəyərin altında görünən kiçik izah mətni.</div>
                        </div>

                        <!-- Sıralama -->
                        <div class="col-md-6 col-12">
                            <label asp-for="Order" class="form-label"></label>
                            <input asp-for="Order" class="form-control" type="number" min="1" />
                            <span asp-validation-for="Order" class="text-danger fs-7"></span>
                        </div>

                        <!-- Status -->
                        <div class="col-md-6 col-12">
                            <label asp-for="IsActive" class="form-label"></label>
                            <select asp-for="IsActive" class="form-select">
                                <option value="true">Aktiv</option>
                                <option value="false">Deaktiv</option>
                            </select>
                            <span asp-validation-for="IsActive" class="text-danger fs-7"></span>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex gap-2 justify-content-end">
                        <a asp-area="Admin" asp-controller="Statistics" asp-action="Index" class="btn btn-outline-secondary">İmtina Et</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Göstəricini Yarat</button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</main>
