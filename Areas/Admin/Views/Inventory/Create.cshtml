@model ModernWMC.Areas.Admin.ViewModels.InventoryViewModel

<main id="main">
    <div class="content">
        <div class="pg-header">
            <div>
                <h4>Yeni Məhsul Əlavə Et</h4>
                <p>Sistemə yeni məhsul kartı və ilkin stok məlumatlarını daxil edin.</p>
            </div>
            <div>
                <a asp-area="Admin" asp-controller="Inventory" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Geri Qayıt
                </a>
            </div>
        </div>

        <div class="cc">
            <div class="cc-head">
                <h5 class="cc-title"><i class="bi bi-box-seam me-2 text-primary"></i>Məhsul Məlumat Forması</h5>
            </div>
            <div class="cc-body p24">
                <form method="POST" asp-area="Admin" asp-controller="Inventory" asp-action="Create">
                    <div class="row g-3">
                        <!-- Məhsul Adı -->
                        <div class="col-12 col-md-8">
                            <label class="form-label" asp-for="Name">Məhsul Adı <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" asp-for="Name" required placeholder="Məsələn: Laptop Dell XPS 15" />
                            <span asp-validation-for="Name" class="text-danger fs-7"></span>
                        </div>
                        <!-- SKU -->
                        <div class="col-12 col-md-4">
                            <label class="form-label" asp-for="SKU">SKU (Kod) <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" asp-for="SKU" required placeholder="Məsələn: PRD-DELL-XPS15" />
                            <span asp-validation-for="SKU" class="text-danger fs-7"></span>
                        </div>

                        <!-- Kateqoriya -->
                        <div class="col-12 col-md-6">
                            <label class="form-label" asp-for="CategoryId">Kateqoriya <span class="text-danger">*</span></label>
                            <select class="form-select" asp-for="CategoryId" asp-items="ViewBag.Categories" required>
                                <option value="">Kateqoriya seçin...</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger fs-7"></span>
                        </div>
                        <!-- Ölçü Vahidi -->
                        <div class="col-12 col-md-6">
                            <label class="form-label" asp-for="MeasureUnitId">Ölçü Vahidi <span class="text-danger">*</span></label>
                            <select class="form-select" asp-for="MeasureUnitId" asp-items="ViewBag.MeasureUnits" required>
                                <option value="">Ölçü vahidi seçin...</option>
                            </select>
                            <span asp-validation-for="MeasureUnitId" class="text-danger fs-7"></span>
                        </div>

                        <!-- Yerləşdiriləcək Anbar -->
                        <div class="col-12 col-md-6">
                            <label class="form-label" asp-for="WarehouseId">Yerləşdiriləcək Anbar <span class="text-danger">*</span></label>
                            <select class="form-select" asp-for="WarehouseId" asp-items="ViewBag.Warehouses" required>
                                <option value="">Anbar seçin...</option>
                            </select>
                            <span asp-validation-for="WarehouseId" class="text-danger fs-7"></span>
                        </div>
                        <!-- Rəf / Zona -->
                        <div class="col-12 col-md-6">
                            <label class="form-label" asp-for="ShelfLocation">Rəf / Zona (Lokasiya)</label>
                            <input type="text" class="form-control" asp-for="ShelfLocation" placeholder="Məsələn: Zone-A / Rəf-04" />
                            <span asp-validation-for="ShelfLocation" class="text-danger fs-7"></span>
                        </div>

                        <!-- İlkin Stok Miqdarı -->
                        <div class="col-12 col-md-6">
                            <label class="form-label" asp-for="Quantity">İlkin Stok Miqdarı</label>
                            <input type="number" class="form-control" asp-for="Quantity" min="0" value="0" />
                            <span class="form-text text-muted">Məhsul sistemə daxil edildikdə avtomatik olaraq bu sayda stok əlavə ediləcək.</span>
                            <span asp-validation-for="Quantity" class="text-danger fs-7"></span>
                        </div>
                        <!-- Kritik Hədd (Limit) -->
                        <div class="col-12 col-md-6">
                            <label class="form-label" asp-for="CriticalLimit">Kritik Stok Həddi (Limit) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" asp-for="CriticalLimit" min="1" value="5" required />
                            <span class="form-text text-muted">Stok bu saydan aşağı düşdükdə kritik xəbərdarlıq bildirişi göstəriləcək.</span>
                            <span asp-validation-for="CriticalLimit" class="text-danger fs-7"></span>
                        </div>

                        <!-- Partiya və Son İstifadə Tarixi -->
                        <div class="col-12 col-md-6">
                            <label class="form-label" asp-for="LotNo">Partiya (Lot No)</label>
                            <input type="text" class="form-control" asp-for="LotNo" placeholder="Məsələn: LOT-10293" />
                            <span asp-validation-for="LotNo" class="text-danger fs-7"></span>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label" asp-for="ExpirationDate">Son İstifadə Tarixi</label>
                            <input type="date" class="form-control" asp-for="ExpirationDate" />
                            <span asp-validation-for="ExpirationDate" class="text-danger fs-7"></span>
                        </div>

                        <!-- Status (Aktiv) -->
                        <div class="col-12 col-md-2 d-flex align-items-end mb-2">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" id="isActiveSwitch" />
                                <label class="form-check-label fw-semibold" for="isActiveSwitch" asp-for="IsActive">Status (Aktiv)</label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex gap-2 justify-content-end">
                        <a asp-area="Admin" asp-controller="Inventory" asp-action="Index" class="btn btn-outline-secondary">İmtina Et</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Yadda Saxla</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>
