@model ModernWMC.Areas.Admin.ViewModels.MeasureUnitViewModel

<main id="main">
    <div class="content">
        <div class="pg-header">
            <div>
                <h4>Yeni Ölçü Vahidi Əlavə Et</h4>
                <p>Sistemə yeni ölçü vahidi (məs. kiloqram, litr, qutu və s.) daxil edin.</p>
            </div>
            <div>
                <a asp-area="Admin" asp-controller="MeasureUnits" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Geri Qayıt
                </a>
            </div>
        </div>

        <div class="cc">
            <div class="cc-head">
                <h5 class="cc-title"><i class="bi bi-rulers me-2 text-primary"></i>Ölçü Vahidi Məlumat Forması</h5>
            </div>
            <div class="cc-body p24">
                <form method="POST" asp-area="Admin" asp-controller="MeasureUnits" asp-action="Create">
                    <div class="row g-3">
                        <!-- Name -->
                        <div class="col-12 col-md-8">
                            <label class="form-label" asp-for="Name">Ölçü Vahidi Adı <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" asp-for="Name" required placeholder="Məsələn: Kiloqram" />
                            <span asp-validation-for="Name" class="text-danger fs-7"></span>
                        </div>
                        <!-- Code -->
                        <div class="col-12 col-md-4">
                            <label class="form-label" asp-for="Code">Qısa Kod <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" asp-for="Code" required placeholder="Məsələn: kq" />
                            <span asp-validation-for="Code" class="text-danger fs-7"></span>
                        </div>

                        <!-- Description -->
                        <div class="col-12 col-md-9">
                            <label class="form-label" asp-for="Description">Açıqlama</label>
                            <textarea class="form-control" asp-for="Description" rows="4" placeholder="Ölçü vahidi haqqında ətraflı məlumat daxil edin..."></textarea>
                            <span asp-validation-for="Description" class="text-danger fs-7"></span>
                        </div>

                        <!-- IsActive -->
                        <div class="col-12 col-md-3 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" id="isActiveSwitch" />
                                <label class="form-check-label fw-semibold" for="isActiveSwitch" asp-for="IsActive">Status (Aktiv)</label>
                                <span asp-validation-for="IsActive" class="text-danger fs-7"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex gap-2 justify-content-end">
                        <a asp-area="Admin" asp-controller="MeasureUnits" asp-action="Index" class="btn btn-outline-secondary">İmtina Et</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Yadda Saxla</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>
