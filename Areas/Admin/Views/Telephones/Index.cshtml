@model IEnumerable<ModernWMC.Areas.Admin.ViewModels.PhoneViewModel>

<main id="main">
    <div class="content">
        
        <div class="pg-header">
            <div>
                <h4>Şirkət Telefon Nömrələri</h4>
                <p>İctimai 'Əlaqə' səhifəsində göstərilən əlaqə telefon nömrələrini idarə edin.</p>
            </div>
            <div>
                <a asp-area="Admin" asp-controller="Telephones" asp-action="Create" class="btn btn-sm btn-primary shadow-sm">
                    <i class="bi bi-plus-lg me-1"></i> Yeni Telefon
                </a>
            </div>
        </div>

        <div class="cc">
            <div class="cc-head">
                <h5 class="cc-title">Telefonların Siyahısı</h5>
                <span class="badge bg-secondary">Cəmi: @Model.Count() telefon</span>
            </div>
            <div class="cc-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="table-responsive">
                    <table class="table erp-table align-middle">
                        <thead>
                            <tr>
                                <th style="width: 80px;" class="text-center">ID</th>
                                <th>Növ / Etiket</th>
                                <th>Telefon Nömrəsi</th>
                                <th class="text-center" style="width: 100px;">Sıralama</th>
                                <th class="text-center" style="width: 100px;">Status</th>
                                <th class="text-center" style="width: 150px;">Əməliyyatlar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center fw-bold">@item.Id</td>
                                    <td>
                                        <span class="badge bg-primary-subtle text-primary fs-8 px-2">@item.Title</span>
                                    </td>
                                    <td><strong>@item.Label</strong></td>
                                    <td class="text-center">@item.Order</td>
                                    <td class="text-center">
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success fs-8 px-2">Aktiv</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger fs-8 px-2">Deaktiv</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-1">
                                            <!-- Düzəliş et -->
                                            <a asp-area="Admin" asp-controller="Telephones" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-xs btn-outline-primary act-btn" title="Düzəliş et">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <!-- Sil -->
                                            <form id="delete-form-@item.Id" asp-area="Admin" asp-controller="Telephones" asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:none;"></form>
                                            <button type="button" class="btn btn-xs btn-outline-danger act-btn" title="Sil" onclick="deletePhone(@item.Id, '@item.Label')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">Siyahı boşdur.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</main>

@section Scripts {
    <script>
        function deletePhone(id, phone) {
            if (confirm(`"${phone}" nömrəsini silmək istədiyinizə əminsiniz?`)) {
                document.getElementById('delete-form-' + id).submit();
            }
        }
    </script>
}
