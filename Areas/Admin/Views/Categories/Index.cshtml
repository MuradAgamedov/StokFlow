@model IEnumerable<ModernWMC.Areas.Admin.ViewModels.CategoryViewModel>

<main id="main">
    <div class="content">

        <!-- Page Header -->
        <div class="pg-header">
            <div>
                <h4>Kateqoriyaların İdarə Edilməsi</h4>
                <p>Məhsulların kateqoriya üzrə qruplaşdırılması, kodlaşdırılması və ümumi stok analizləri.</p>
            </div>
            <div>
                <a asp-area="Admin" asp-controller="Categories" asp-action="Create" class="btn btn-sm btn-primary shadow-sm">
                    <i class="bi bi-plus-lg me-1"></i> Yeni Kateqoriya
                </a>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Search Panel -->
        <div class="filter-card mb-4">
            <form method="GET" asp-area="Admin" asp-controller="Categories" asp-action="Index">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="searchQuery">Kateqoriya Axtar</label>
                        <input type="text" class="form-control form-control-sm" id="searchQuery" name="search" value="@ViewData["CurrentFilter"]" placeholder="Kateqoriya adı və ya kod..." />
                    </div>
                    <div class="col-12 col-md-3">
                        <button type="submit" class="btn btn-sm btn-primary w-100">
                            <i class="bi bi-funnel me-1"></i> Filtrlə
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Category Table Card -->
        <div class="cc">
            <div class="cc-head">
                <h5 class="cc-title">Kateqoriya Siyahısı</h5>
                <span class="badge bg-secondary">Cəmi: @(Model?.Count() ?? 0) kateqoriya</span>
            </div>
            <div class="cc-body">
                <div class="table-responsive">
                    <table class="table erp-table align-middle">
                        <thead>
                            <tr>
                                <th>KOD</th>
                                <th>Kateqoriya Adı</th>
                                <th>Açıqlama</th>
                                <th class="text-end">Məhsul Çeşidi</th>
                                <th class="text-center">Status</th>
                                <th class="text-center">Əməliyyatlar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td><span class="sku">@item.CategoryCode</span></td>
                                        <td><strong>@item.Name</strong></td>
                                        <td>@item.Description</td>
                                        <td class="text-end fw-bold">0 məhsul</td>
                                        <td class="text-center"><span class="sbadge s-ok">Aktiv</span></td>
                                        <td class="text-center">
                                            <div class="d-flex justify-content-center gap-1">
                                                <a asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-xs btn-outline-primary act-btn" title="Düzəliş et">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form asp-area="Admin" asp-controller="Categories" asp-action="Delete" asp-route-id="@item.Id" method="POST" class="d-inline" onsubmit="return confirm('Bu kateqoriyanı silmək istədiyinizə əminsiniz?')">
                                                    <button type="submit" class="btn btn-xs btn-outline-danger act-btn" title="Sil">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">Sistemdə heç bir kateqoriya tapılmadı.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</main>
