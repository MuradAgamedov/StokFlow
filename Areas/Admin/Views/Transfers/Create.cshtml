@model ModernWMC.Areas.Admin.ViewModels.TransferViewModel

<main id="main">
    <div class="content">
        <div class="pg-header">
            <div>
                <h4>Yeni Anbarlararası Transfer</h4>
                <p>Mənbə anbardakı mövcud məhsulları hədəf anbarına göndərin.</p>
            </div>
            <div>
                <a asp-area="Admin" asp-controller="Transfers" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Geri Qayıt
                </a>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> Zəhmət olmasa formdakı xətaları düzəldin.
                <div asp-validation-summary="All" class="fs-7 mt-1"></div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="cc">
            <div class="cc-head">
                <h5 class="cc-title"><i class="bi bi-arrow-left-right me-2 text-primary"></i>Transfer Qeydiyyat Forması</h5>
            </div>
            <div class="cc-body p24">
                <form method="POST" asp-area="Admin" asp-controller="Transfers" asp-action="Create" id="poForm">
                    <div class="row g-3 mb-4">
                        <!-- Source Warehouse -->
                        <div class="col-12 col-md-6">
                            <label class="form-label" asp-for="SourceWarehouseId">Mənbə Anbar (Çıxış) <span class="text-danger">*</span></label>
                            <select class="form-select" asp-for="SourceWarehouseId" asp-items="ViewBag.Warehouses" required>
                                <option value="">Çıxış anbarını seçin...</option>
                            </select>
                            <span asp-validation-for="SourceWarehouseId" class="text-danger fs-7"></span>
                        </div>
                        <!-- Destination Warehouse -->
                        <div class="col-12 col-md-6">
                            <label class="form-label" asp-for="DestinationWarehouseId">Hədəf Anbar (Giriş) <span class="text-danger">*</span></label>
                            <select class="form-select" asp-for="DestinationWarehouseId" asp-items="ViewBag.Warehouses" required>
                                <option value="">Giriş anbarını seçin...</option>
                            </select>
                            <span asp-validation-for="DestinationWarehouseId" class="text-danger fs-7"></span>
                        </div>
                    </div>

                    <!-- Dynamic Product Rows Label -->
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <h6 class="mb-0 fw-bold"><i class="bi bi-list-task me-1"></i>Transfer Məhsulları</h6>
                        <button type="button" class="btn btn-xs btn-outline-primary" id="addPoRow" disabled>
                            <i class="bi bi-plus-lg me-1"></i> Məhsul Sətri Əlavə Et
                        </button>
                    </div>

                    <!-- Dynamic Product Rows Container -->
                    <div id="poContainer">
                        <!-- Rows will be dynamically loaded via Javascript depending on the selected Source Warehouse -->
                        <div class="text-center py-4 text-muted border rounded mb-3 bg-light-subtle" id="noWarehouseMessage">
                            <i class="bi bi-info-circle me-1"></i> Məhsulları seçmək üçün əvvəlcə Mənbə Anbarı (Çıxış) müəyyənləşdirin.
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex gap-2 justify-content-end">
                        <a asp-area="Admin" asp-controller="Transfers" asp-action="Index" class="btn btn-outline-secondary">İmtina Et</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-send me-1"></i> Transferi Yola Sal</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        let availableInventories = [];

        // When source warehouse changes, fetch inventories and clear rows
        document.getElementById('SourceWarehouseId').addEventListener('change', function () {
            const whId = this.value;
            const container = document.getElementById('poContainer');
            const addBtn = document.getElementById('addPoRow');
            const noMsg = document.getElementById('noWarehouseMessage');

            container.innerHTML = '';
            availableInventories = [];

            if (!whId) {
                addBtn.disabled = true;
                if (!noMsg) {
                    const msg = document.createElement('div');
                    msg.id = 'noWarehouseMessage';
                    msg.className = 'text-center py-4 text-muted border rounded mb-3 bg-light-subtle';
                    msg.innerHTML = '<i class="bi bi-info-circle me-1"></i> Məhsulları seçmək üçün əvvəlcə Mənbə Anbarı (Çıxış) müəyyənləşdirin.';
                    container.appendChild(msg);
                }
                return;
            }

            addBtn.disabled = true;
            container.innerHTML = '<div class="text-center py-4 text-primary"><div class="spinner-border spinner-border-sm me-2" role="status"></div>Məhsul siyahısı yüklənir...</div>';

            fetch(`/Admin/Transfers/GetInventoriesByWarehouse?warehouseId=${whId}`)
                .then(res => res.json())
                .then(data => {
                    availableInventories = data;
                    container.innerHTML = '';
                    addBtn.disabled = false;

                    if (availableInventories.length === 0) {
                        const msg = document.createElement('div');
                        msg.className = 'text-center py-4 text-warning border rounded mb-3 bg-warning-subtle';
                        msg.innerHTML = '<i class="bi bi-exclamation-triangle me-1"></i> Seçilmiş anbarın stokunda heç bir məhsul yoxdur.';
                        container.appendChild(msg);
                        addBtn.disabled = true;
                    } else {
                        addTransferRow();
                    }
                })
                .catch(err => {
                    container.innerHTML = '<div class="text-center py-4 text-danger"><i class="bi bi-exclamation-circle me-2"></i>Məhsulları yükləyərkən xəta baş verdi.</div>';
                    console.error(err);
                });
        });

        // Add row template
        document.getElementById('addPoRow').addEventListener('click', addTransferRow);

        function addTransferRow() {
            const container = document.getElementById('poContainer');
            const index = container.querySelectorAll('.prod-row').length;

            const newRow = document.createElement('div');
            newRow.className = 'prod-row mb-3';
            newRow.id = `pr${index}`;

            let optionsHtml = '<option value="">Məhsul seçin...</option>';
            availableInventories.forEach(inv => {
                optionsHtml += `<option value="${inv.id}" data-stock="${inv.availableQuantity}" data-unit="${inv.measureUnitCode}">${inv.name}</option>`;
            });

            newRow.innerHTML = `
                <div class="row g-2 align-items-center">
                    <div class="col-md-5">
                        <label class="form-label text-muted fs-8 mb-1">Məhsul</label>
                        <select name="Items[${index}].InventoryId" class="form-select form-select-sm po-prod-select" required>
                            ${optionsHtml}
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label text-muted fs-8 mb-1">Mövcud Stok</label>
                        <input type="text" class="form-control form-control-sm item-avail-stock" readonly value="0" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label text-muted fs-8 mb-1">Ölçü Vahidi</label>
                        <input type="text" class="form-control form-control-sm item-unit" readonly value="—" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label text-muted fs-8 mb-1">Transfer Miqdarı</label>
                        <input type="number" name="Items[${index}].Quantity" class="form-control form-control-sm po-qty" min="1" value="1" required disabled />
                    </div>
                    <div class="col-md-1 d-flex align-items-end" style="margin-top: 1.5rem;">
                        <button type="button" class="btn btn-sm btn-outline-danger w-100 remove-row-btn" onclick="removeRow(${index})"><i class="bi bi-trash"></i></button>
                    </div>
                </div>
            `;

            container.appendChild(newRow);
            updateRemoveButtons();
        }

        // Remove row logic
        window.removeRow = function (id) {
            const row = document.getElementById(`pr${id}`);
            if (row) {
                row.remove();
                reindexRows();
                updateRemoveButtons();
            }
        };

        // Re-index all name attributes so they bind sequentially in MVC
        function reindexRows() {
            const container = document.getElementById('poContainer');
            const rows = container.querySelectorAll('.prod-row');
            rows.forEach((row, idx) => {
                row.id = `pr${idx}`;
                row.querySelector('.po-prod-select').name = `Items[${idx}].InventoryId`;
                row.querySelector('.po-qty').name = `Items[${idx}].Quantity`;
                row.querySelector('.remove-row-btn').setAttribute('onclick', `removeRow(${idx})`);
            });
        }

        // Disable remove button if only 1 row exists
        function updateRemoveButtons() {
            const container = document.getElementById('poContainer');
            const rows = container.querySelectorAll('.prod-row');
            const removeBtns = container.querySelectorAll('.remove-row-btn');
            if (rows.length <= 1) {
                removeBtns.forEach(btn => btn.style.display = 'none');
            } else {
                removeBtns.forEach(btn => btn.style.display = 'block');
            }
        }

        // When a product is selected inside a row
        document.getElementById('poContainer').addEventListener('change', function (e) {
            if (e.target.classList.contains('po-prod-select')) {
                const select = e.target;
                const row = select.closest('.prod-row');
                const option = select.options[select.selectedIndex];
                const stockInput = row.querySelector('.item-avail-stock');
                const unitInput = row.querySelector('.item-unit');
                const qtyInput = row.querySelector('.po-qty');

                if (select.value) {
                    const stock = option.getAttribute('data-stock');
                    const unit = option.getAttribute('data-unit');

                    stockInput.value = stock;
                    unitInput.value = unit;
                    qtyInput.disabled = false;
                    qtyInput.setAttribute('max', stock);
                    qtyInput.value = 1;
                } else {
                    stockInput.value = '0';
                    unitInput.value = '—';
                    qtyInput.disabled = true;
                    qtyInput.removeAttribute('max');
                    qtyInput.value = '';
                }
            }
        });

        // Quantity limits check
        document.getElementById('poContainer').addEventListener('input', function (e) {
            if (e.target.classList.contains('po-qty')) {
                const qtyInput = e.target;
                const maxVal = parseInt(qtyInput.getAttribute('max')) || 0;
                const currentVal = parseInt(qtyInput.value) || 0;

                if (currentVal > maxVal) {
                    qtyInput.setCustomValidity(`Göndəriləcək miqdar mövcud stokdan (${maxVal}) çox ola bilməz.`);
                    qtyInput.reportValidity();
                } else {
                    qtyInput.setCustomValidity('');
                }
            }
        });

        // Prevent submitting same source and destination
        document.getElementById('poForm').addEventListener('submit', function (e) {
            const src = document.getElementById('SourceWarehouseId').value;
            const dest = document.getElementById('DestinationWarehouseId').value;
            if (src && dest && src === dest) {
                e.preventDefault();
                alert('Mənbə və hədəf anbar eyni ola bilməz!');
                return false;
            }

            const rows = document.querySelectorAll('.prod-row');
            if (rows.length === 0) {
                e.preventDefault();
                alert('Ən azı bir məhsul daxil edilməlidir!');
                return false;
            }
        });

        // Handle validation reload initialization
        document.addEventListener('DOMContentLoaded', function () {
            const srcSelect = document.getElementById('SourceWarehouseId');
            if (srcSelect && srcSelect.value) {
                srcSelect.dispatchEvent(new Event('change'));
            }
        });
    </script>
}
