@model ModernWMC.Areas.Admin.ViewModels.TransferViewModel

<main id="main">
    <div class="content">

        <!-- Page Header -->
        <div class="pg-header">
            <div>
                <h4>Transfer Detalları</h4>
                <p>Transfer nömrəsi: <span class="fw-bold text-primary">@Model.TransferNumber</span></p>
            </div>
            <div>
                <a asp-area="Admin" asp-controller="Transfers" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Siyahıya Qayıt
                </a>
            </div>
        </div>

        <div class="row g-4">
            <!-- Transfer Info Summary Card -->
            <div class="col-12 col-lg-4">
                <div class="cc h-100">
                    <div class="cc-head">
                        <h5 class="cc-title"><i class="bi bi-info-circle-fill me-2 text-primary"></i>Ümumi Məlumat</h5>
                    </div>
                    <div class="cc-body p24">
                        <div class="mb-3 border-bottom pb-2">
                            <label class="text-secondary small d-block">Transfer Nömrəsi</label>
                            <span class="fw-bold fs-6">@Model.TransferNumber</span>
                        </div>
                        <div class="mb-3 border-bottom pb-2">
                            <label class="text-secondary small d-block">Mənbə Anbar (Çıxış)</label>
                            <span class="fw-semibold">@Model.SourceWarehouseName</span>
                        </div>
                        <div class="mb-3 border-bottom pb-2">
                            <label class="text-secondary small d-block">Hədəf Anbar (Giriş)</label>
                            <span class="fw-semibold text-success">@Model.DestinationWarehouseName</span>
                        </div>
                        <div class="mb-3 border-bottom pb-2">
                            <label class="text-secondary small d-block">Göndərilmə Tarixi</label>
                            <span>@Model.SendDate.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <div class="mb-3">
                            <label class="text-secondary small d-block">Status</label>
                            @{
                                var badgeClass = "s-transit";
                                var statusText = "Yoldadır";

                                if (Model.Status == "Completed")
                                {
                                    badgeClass = "s-done";
                                    statusText = "Tamamlandı";
                                }
                            }
                            <span class="sbadge @badgeClass mt-1">@statusText</span>
                        </div>

                        @if (Model.Status == "InTransit")
                        {
                            <div class="mt-4 pt-3 border-top d-flex gap-2">
                                <form asp-area="Admin" asp-controller="Transfers" asp-action="Complete" asp-route-id="@Model.Id" method="POST" class="w-100" onsubmit="return confirm('Məhsulların hədəf anbarında qəbulunu təsdiqləyirsiniz?');">
                                    <button type="submit" class="btn btn-success w-100">
                                        <i class="bi bi-box-arrow-in-down me-1"></i> Məhsulları Qəbul Et (Təhvil Al)
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Transfer Items List Card -->
            <div class="col-12 col-lg-8">
                <div class="cc h-100">
                    <div class="cc-head">
                        <h5 class="cc-title"><i class="bi bi-list-task me-2 text-primary"></i>Transfer Olunan Məhsullar</h5>
                        <span class="badge bg-secondary">@Model.Items.Count məhsul növü</span>
                    </div>
                    <div class="cc-body">
                        <div class="table-responsive">
                            <table class="table erp-table align-middle">
                                <thead>
                                    <tr>
                                        <th>SKU</th>
                                        <th>Məhsul Adı</th>
                                        <th class="text-end">Transfer Miqdarı</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Items)
                                    {
                                        <tr>
                                            <td><span class="sku">@item.ProductSKU</span></td>
                                            <td><strong>@item.ProductName</strong></td>
                                            <td class="text-end fw-bold text-primary">@item.Quantity @item.MeasureUnitCode</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</main>

@section Scripts {
    <style>
        .s-transit {
            background-color: rgba(13, 202, 240, 0.15);
            color: #0dcaf0;
        }
        .s-done {
            background-color: rgba(25, 135, 84, 0.15);
            color: #198754;
        }
    </style>
}
