@model ModernWMC.Areas.Admin.ViewModels.PrivacyPolicyViewModel

<main id="main">
    <div class="content">
        <div class="pg-header">
            <div>
                <h4>Gizlilik Siyasəti Səhifəsi Məlumatları</h4>
                <p>İctimai 'Gizlilik Siyasəti' səhifəsində görünən mətnləri və qaydaları buradan tənzimləyin.</p>
            </div>
            <div>
                <a asp-area="" asp-controller="PrivacyPolicy" asp-action="Index" target="_blank" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-eye me-1"></i> Səhifəyə Baxış
                </a>
            </div>
        </div>

        <div class="cc">
            <div class="cc-head">
                <h5 class="cc-title"><i class="bi bi-shield-lock me-2 text-primary"></i>Gizlilik Şərtləri Forması</h5>
            </div>
            <div class="cc-body p24">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form method="POST" asp-area="Admin" asp-controller="Privacy" asp-action="Index">
                    <input type="hidden" asp-for="Id" />
                    <div class="row g-3">
                        <!-- Səhifə Başlığı -->
                        <div class="col-md-6 col-12">
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger fs-7"></span>
                        </div>

                        <!-- Alt Başlıq (Subtext) -->
                        <div class="col-md-6 col-12">
                            <label asp-for="Subtext" class="form-label"></label>
                            <input asp-for="Subtext" class="form-control" />
                            <span asp-validation-for="Subtext" class="text-danger fs-7"></span>
                        </div>

                        <!-- Gövdə Mətni (Rich HTML text area) -->
                        <div class="col-12 mt-4">
                            <label asp-for="BodyContent" class="form-label fw-semibold text-primary"></label>
                            <textarea class="form-control" id="PageContent" asp-for="BodyContent"></textarea>
                            <span asp-validation-for="BodyContent" class="text-danger fs-7"></span>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-outline-secondary" onclick="window.location.reload();">İmtina Et</button>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Dəyişiklikləri Saxla</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <!-- CKEditor CDN -->
    <script src="https://cdn.ckeditor.com/ckeditor5/36.0.1/classic/ckeditor.js"></script>

    <!-- CKEditor Initialization -->
    <script>
        ClassicEditor
            .create(document.querySelector('#PageContent'), {
                toolbar: [ 'heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', 'undo', 'redo' ]
            })
            .catch(error => {
                console.error(error);
            });
    </script>
}
