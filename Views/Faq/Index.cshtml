@model FAQViewModel
@{
    ViewData["Title"] = "B2B Təchizat və Anbar İdarəetmə ERP Sistemi";
}
@section PageCss {
    <link href="~/css/faq.css" rel="stylesheet">
}
<!-- HERO SECTION -->
<section class="subpage-hero">
    <div class="container text-center">
        <h1 class="display-4 mb-3">Tez-tez Verilən Suallar</h1>
        <p class="text-secondary max-width-600 mx-auto">WMS Pro haqqında ən çox verilən suallar və onların ətraflı cavabları.</p>
    </div>
</section>

<!-- CONTENT SECTION -->
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="accordion" id="faqAccordion">

                    @for (int i = 0; i < Model.FAQ.Count; i++)
                    {
                        var faq = Model.FAQ[i];

                        <div class="accordion-item bg-card border mb-3 rounded overflow-hidden">
                            <h2 class="accordion-header" id="heading-@i">
                                <button class="accordion-button fw-semibold @(i != 0 ? "collapsed" : "")"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#collapse-@i"
                                        aria-expanded="@(i == 0 ? "true" : "false")"
                                        aria-controls="collapse-@i">
                                    @faq.Question
                                </button>
                            </h2>

                            <div id="collapse-@i"
                                 class="accordion-collapse collapse @(i == 0 ? "show" : "")"
                                 aria-labelledby="heading-@i"
                                 data-bs-parent="#faqAccordion">
                                <div class="accordion-body text-secondary fs-8">
                                    @faq.Answer
                                </div>
                            </div>
                        </div>
                    }

      
                   

                </div>

            </div>
        </div>
    </div>
</section>
