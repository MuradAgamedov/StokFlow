@model ContactPageViewModel

@section PageCss {
    <link href="~/css/contact.css" rel="stylesheet">
}

<!-- HERO SECTION -->
<section class="subpage-hero">
    <div class="container text-center">
        <h1 class="display-4 mb-3">Bizimlə Əlaqə</h1>
        <p class="text-secondary max-width-600 mx-auto">Sualınız və ya hər hansı bir təklifiniz var? Formu doldurun və
            ya qeyd olunan kanallarla bizimlə əlaqə saxlayın.</p>
    </div>
</section>

<!-- CONTACT DETAILS & FORM -->
<section class="py-5">
    <div class="container">
        <!-- Info Cards -->
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="p-4 contact-card h-100">
                    <div class="contact-icon">
                        <i class="bi bi-geo-alt-fill"></i>
                    </div>
                    <h5>Ünvanımız</h5>
                    @foreach (var address in Model.Contact.Addresses)
                    {
                        <p class="text-secondary mb-1">@address.Label</p>
                    }
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 contact-card h-100">
                    <div class="contact-icon">
                        <i class="bi bi-telephone-fill"></i>
                    </div>
                    <h5>Telefon</h5>
                    @foreach (var phone in Model.Contact.Phones)
                    {
                        <p class="text-secondary mb-1">@phone.Label</p>
                    }
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 contact-card h-100">
                    <div class="contact-icon">
                        <i class="bi bi-envelope-fill"></i>
                    </div>
                    <h5>E-poçt</h5>
                    @foreach (var email in Model.Contact.Emails)
                    {
                        <p class="text-secondary mb-1">@email.Label</p>
                    }
                </div>
            </div>
        </div>

        <!-- Form and Map -->
        <div class="row g-5">
            <!-- Contact Form -->
            <div class="col-lg-6">
                <div class="p-4 p-md-5 rounded-4 bg-body-tertiary border">
                    <h3 class="mb-4 outfit-font">Bizə Yazın</h3>
                    <form id="contactForm" novalidate asp-controller="Contact" asp-action="Index" method="Post">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" asp-for="Message.FullName"></label><span
                                class="text-danger">*</span>
                                <input type="text" class="form-control" asp-for="Message.FullName"
                                placeholder="Murad Agamedov">
                                <span asp-validation-for="Message.FullName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" asp-for="Message.Email"></label><span
                                class="text-danger">*</span>
                                <input type="email" class="form-control" asp-for="Message.Email"
                                placeholder="murad@example.com">
                                <span asp-validation-for="Message.Email" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label" asp-for="Message.Subject">Mövzu</label>
                                <input type="text" class="form-control" asp-for="Message.Subject"
                                placeholder="Əməkdaşlıq təklifi...">
                                <span asp-validation-for="Message.Subject" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label" asp-for="Message.Message">Mesajınız </label><span
                                class="text-danger">*</span>
                                <textarea class="form-control" id="Message" rows="5" asp-for="Message.Message"
                                placeholder="Mesajınızı buraya daxil edin..."></textarea>
                                <span asp-validation-for="Message.Message" class="text-danger"></span>
                            </div>
                            @* <div asp-validation-summary="All" class="text-danger"></div> *@
                            @if (@TempData["SuccessMessage"] != null)
                            {
                                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                            }
                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary px-4 py-2 text-white">
                                        <i class="bi bi-send-fill me-2"></i> Göndər
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Map Box -->
                <div class="col-lg-6">
                    <div class="map-container shadow-sm h-100">
                        <iframe
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3039.4286748537574!2d49.8517564!3d40.3771908!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x40307d17b5f63457%3A0xc3cf9c916298dc1e!2sNizami%20St%2C%20Baku!5e0!3m2!1sen!2saz!4v1718465000000!5m2!1sen!2saz"
                            width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade">
                        </iframe>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Bootstrap 5 Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom WMS Pro JS -->
    <script src="wwwroot/js/site.js"></script>